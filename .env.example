# .env.example
# Server Configuration
PORT=3003
NODE_ENV=production

# Firebase Configuration (Already handled by firebase-applet-config.json)

# GitHub Build System Integration
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_android_webview_template_repo

# Private Signing Configuration (Base64 encoded JKS or just passwords for now)
KEYSTORE_PASSWORD=your_keystore_password
KEY_ALIAS=your_key_alias
KEY_PASSWORD=your_key_password
